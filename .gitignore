*.pkl
*.joblib
*.h5
*.pb

# Keep metrics JSON (small, useful to track)
!models/*.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
error.log
*.log

# Keep logs directory
!logs/.gitkeep

