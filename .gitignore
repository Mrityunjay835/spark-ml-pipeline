data/processed/
data/features/
data/streaming/input/
data/streaming/checkpoint/
data/streaming/predictions/
*.parquet
*.snappy.parquet
*.csv
*.tsv
*.json.gz

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep
!data/streaming/input/.gitkeep
!data/streaming/checkpoint/.gitkeep

